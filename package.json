{
  "name": "volleytip-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "cross-env APP_ENV=development expo start --dev-client",
    "start:go": "cross-env APP_ENV=development expo start --go",
    "start:prod": "cross-env APP_ENV=production expo start --dev-client",
    "android": "cross-env APP_ENV=development expo start --dev-client --android",
    "ios": "cross-env APP_ENV=development expo start --dev-client --ios",
    "web": "cross-env APP_ENV=development expo start --web",
    "build:android:dev": "eas build --profile development --platform android",
    "build:android": "eas build --profile production --platform android",
    "build:ios": "eas build --profile production --platform ios",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.9",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.0.10",
    "react": "19.1.0",
    "react-i18next": "^17.0.7",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^10.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
